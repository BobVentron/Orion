#!/bin/sh
set -e

# ────────────────────────────────────────────────────────────────
# Démarrage de Docker
# Toutes les dépendances sont configurées ici (contrairement au preinst).
# ────────────────────────────────────────────────────────────────
# ────────────────────────────────────────────────────────────────────────
if command -v systemctl >/dev/null 2>&1; then
    if ! systemctl is-active --quiet docker 2>/dev/null; then
        echo "→ Activation et démarrage du service Docker..."
        systemctl enable docker 2>/dev/null || true
        systemctl start docker 2>/dev/null || {
            echo "⚠️  Impossible de démarrer Docker automatiquement." >&2
            echo "   Lancez manuellement : systemctl start docker" >&2
            echo "   puis : orion-control deploy" >&2
        }
    else
        echo "→ Docker déjà actif."
    fi
fi


if [ -t 1 ]; then
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    CYAN='\033[0;36m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    GREEN=''
    YELLOW=''
    BLUE=''
    CYAN=''
    RED=''
    NC=''
fi

# ────────────────────────────────────────────────────────────────
# Bannière d'installation
# ────────────────────────────────────────────────────────────────
cat << EOF

╔════════════════════════════════════════════════════════════╗
║              ${GREEN}ORION – Installation réussie !${NC}               ║
╚════════════════════════════════════════════════════════════╝

Version : ${YELLOW}0.5.3${NC}

EOF

# ────────────────────────────────────────────────────────────────
# Demande de l'IP publique / nom de domaine
#
# Cette valeur sera intégrée dans le SAN du certificat SSL
# auto-signé pour que le navigateur puisse la valider.
# Elle ne doit PAS être une adresse interne Docker (172.x…)
# ni 127.0.0.1, mais bien l'adresse que l'utilisateur final
# tapera dans son navigateur.
# ────────────────────────────────────────────────────────────────
echo "╔════════════════════════════════════════════════════════════╗"
echo "║          Configuration de l'accès HTTPS                   ║"
echo "╚════════════════════════════════════════════════════════════╝"
echo ""
echo "Orion génère un certificat SSL auto-signé lors du déploiement."
echo "Pour qu'il soit valide pour votre navigateur, il doit contenir"
echo "l'adresse réelle par laquelle vous joindrez l'interface web."
echo ""
echo "${YELLOW}⚠  N'utilisez PAS :${NC}"
echo "   • Une adresse Docker interne (172.x.x.x)"
echo "   • 127.0.0.1 ou localhost (sauf usage strictement local)"
echo ""
echo "${CYAN}Exemples valides :${NC}"
echo "   • 192.168.1.100        (IP fixe de votre serveur sur le LAN)"
echo "   • 10.0.0.50            (IP dans un réseau privé d'entreprise)"
echo "   • orion.mondomaine.fr  (nom de domaine si vous en avez un)"
echo ""

ORION_HOST=""
while [ -z "$ORION_HOST" ]; do
    printf "IP publique ou domaine du serveur Orion : "
    read -r ORION_HOST

    if [ -z "$ORION_HOST" ]; then
        echo "${YELLOW}→ Valeur requise. Entrez l'IP ou le domaine du serveur.${NC}"
    fi
done

echo ""
echo "→ Valeur retenue : ${GREEN}${ORION_HOST}${NC}"

# ────────────────────────────────────────────────────────────────
# Sauvegarde de la configuration
# ────────────────────────────────────────────────────────────────
mkdir -p /etc/orion
chmod 700 /etc/orion

# Mise à jour ou création de server.conf
if [ -f /etc/orion/server.conf ]; then
    sed -i '/^ORION_HOST=/d' /etc/orion/server.conf
fi
echo "ORION_HOST=${ORION_HOST}" >> /etc/orion/server.conf
chmod 600 /etc/orion/server.conf

echo "→ Configuration sauvegardée dans /etc/orion/server.conf"
echo ""

# ────────────────────────────────────────────────────────────────
# Instructions post-installation
# ────────────────────────────────────────────────────────────────
cat << EOF
${CYAN}Pour commencer immédiatement :${NC}

   1. Vérifier la configuration et les prérequis
      ${GREEN}orion-control check${NC}

   2. Déployer et démarrer toute la stack
      ${GREEN}orion-control deploy${NC}
      (un certificat auto-signé est généré automatiquement avec
       l'adresse ${YELLOW}${ORION_HOST}${NC} dans le SAN)

Ensuite vous pourrez :

   • Voir l'état des services      →  ${BLUE}orion-control status${NC}
   • Suivre les logs en direct     →  ${BLUE}orion-control logs${NC}
   • Redémarrer un service         →  ${BLUE}orion-control restart web${NC}
   • Mettre à jour facilement      →  ${BLUE}orion-control update${NC}
   • Tout arrêter proprement       →  ${BLUE}orion-control stop${NC}
   • Tout arrêter et nettoyer      →  ${BLUE}orion-control clear${NC}

${CYAN}Gestion SSL (après le deploy initial) :${NC}

   • Statut du certificat actif    →  ${BLUE}orion-control ssl status${NC}
   • Regénérer le cert auto-signé  →  ${BLUE}orion-control ssl self-signed${NC}
   • Importer Let's Encrypt / CA   →  ${BLUE}orion-control ssl import <crt> <key>${NC}

${YELLOW}Commande d'aide rapide :${NC}
   ${GREEN}orion-control help${NC}

${CYAN}Documentation complète :${NC}
   → /usr/share/orion/README.md
   → Ou : orion.duckinc.soleilhac.me

${GREEN}Votre instance Orion est prête à être déployée !${NC}
Bonne continuation !

EOF

exit 0
