# ───────────────────────────────────────────────────────────────
# Image de base : nginx lightweight
# ───────────────────────────────────────────────────────────────
FROM nginx:alpine

# ───────────────────────────────────────────────────────────────
# Dépendances : openssl pour la génération du cert de secours
# ───────────────────────────────────────────────────────────────
RUN apk add --no-cache openssl curl

# ───────────────────────────────────────────────────────────────
# Certificat de secours intégré à l'image
#
# Stocké dans /etc/nginx/ssl-builtin/ (jamais écrasé par le volume
# docker-compose qui monte /etc/nginx/ssl/).
# L'entrypoint.sh le copie vers /etc/nginx/ssl/ si ce dossier est vide.
#
# ⚠ Ce cert est un fallback de dernier recours (CN=orion.local).
#   En production, orion-control génère un cert avec l'IP/domaine réel
#   dans /etc/orion/ssl/, monté via le volume docker-compose.
# ───────────────────────────────────────────────────────────────
RUN mkdir -p /etc/nginx/ssl-builtin && \
    openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
        -keyout /etc/nginx/ssl-builtin/orion.key \
        -out    /etc/nginx/ssl-builtin/orion.crt \
        -subj "/C=FR/ST=Loire/L=Saint-Etienne/O=Orion/CN=orion.local" \
        2>/dev/null && \
    chmod 600 /etc/nginx/ssl-builtin/orion.key && \
    chmod 644 /etc/nginx/ssl-builtin/orion.crt

# Créer le dossier SSL runtime (sera peuplé par l'entrypoint)
RUN mkdir -p /etc/nginx/ssl

# ───────────────────────────────────────────────────────────────
# Fichiers statiques + config nginx
# ───────────────────────────────────────────────────────────────
WORKDIR /WEB

COPY --chown=root:root site/          /usr/share/nginx/html/
COPY --chown=root:root nginx.conf     /etc/nginx/conf.d/default.conf
COPY --chown=root:root entrypoint.sh  /entrypoint.sh

RUN chmod +x /entrypoint.sh && \
    rm -f /usr/share/nginx/html/index.html.default

# ───────────────────────────────────────────────────────────────
# NOTE : on ne force PAS USER nginxuser ici car nginx a besoin
# de démarrer en root pour binder les ports 80/443, puis il
# abandonne les privilèges sur ses processus worker via la
# directive "user" de sa configuration interne.
# ───────────────────────────────────────────────────────────────

EXPOSE 80 443

ENTRYPOINT ["/entrypoint.sh"]
